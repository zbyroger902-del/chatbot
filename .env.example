# Generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# JWT auth (shared with backend). Generate with: openssl rand -base64 32
JWT_SECRET=****

# Backend URL for Next.js API routes (server-only). e.g. http://localhost:8000
BACKEND_URL=****

# Backend Postgres (for user store and later pgvector). Port 5433 to avoid conflict with other Postgres on 5432. Start DB with: docker compose up -d db
DATABASE_URL=postgresql+asyncpg://chatbot:chatbot@localhost:5433/chatbot

# The following keys below are automatically created and
# added to your environment when you deploy on Vercel

# Instructions to create an AI Gateway API key here: https://vercel.com/ai-gateway 
# API key required for non-Vercel deployments
# For Vercel deployments, OIDC tokens are used automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****


# Instructions to create a Vercel Blob Store here: https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# Instructions to create a PostgreSQL database here: https://vercel.com/docs/postgres
POSTGRES_URL=****


# Instructions to create a Redis store here:
# https://vercel.com/docs/redis
REDIS_URL=****
